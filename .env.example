# Quant-Investor runtime configuration
# 复制此文件为 .env 并填入实际值

# Tushare API Token
# 从 https://tushare.pro/ 获取
TUSHARE_TOKEN=your_tushare_token_here

# Tushare API URL（可选，使用代理时设置）
TUSHARE_URL=http://lianghua.nanyangqiankun.top

# Unified LLM gateway providers
KIMI_API_KEY=your_kimi_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
FRED_API_KEY=your_fred_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Web / workspace runtime
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data / database paths
DB_PATH=data/stock_database.db
APP_DB_PATH=data/app.db

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Results / artifacts
RESULTS_DIR=results
WEB_ANALYSIS_DIR=results/web_analysis

# Redis（仅在显式启用相关能力时使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 回测配置
INITIAL_CASH=1000000
COMMISSION_RATE=0.0003
STAMP_DUTY_RATE=0.001
SLIPPAGE=0.001
